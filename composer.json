{
    "name": "phpsoftbox/cli-app",
    "description": "Консольный компонент (CliApp) для PhpSoftBox Framework",
    "type": "library",
    "require": {
        "php": "^8.4",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2",
        "phpsoftbox/cs-fixer": "^0.1.0@beta",
        "friendsofphp/php-cs-fixer": "^3.93"
    },
    "autoload": {
        "psr-4": {
            "PhpSoftBox\\CliApp\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PhpSoftBox\\CliApp\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/psb"
    ],
    "scripts": {
        "test": "phpunit",
        "cs:fix": "vendor/bin/psb-cs-fixer fix",
        "cs:check": "vendor/bin/psb-cs-fixer check --diff"
    },
    "minimum-stability": "beta",
    "repositories": [
        { "type": "vcs", "url": "git@github.com:phpsoftbox/cs-fixer.git", "no-api": true }
    ]
}
